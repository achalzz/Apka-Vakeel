{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "frontend/.next",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:3001/api/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "http://localhost:3001"
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  }
}
